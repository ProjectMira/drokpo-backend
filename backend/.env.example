FIREBASE_PROJECT_ID=drokpo-backend
# Bucket naming varies by project age: projects created after Oct 2024 get
# <project-id>.firebasestorage.app; older projects get <project-id>.appspot.com.
# Check Firebase Console -> Storage, or `gcloud storage buckets list`, rather
# than assuming the pattern.
STORAGE_BUCKET=drokpo-backend.firebasestorage.app
# Path to a service account JSON key, used for local development only.
# On Cloud Run, leave unset so Application Default Credentials (the
# service's attached identity) are used instead.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
